{
  "productName": "Yakumo API",
  "version": "0.0.3",
  "identifier": "app.yakumo.api",
  "build": {
    "beforeBuildCommand": "bun run build",
    "beforeDevCommand": "bun run --cwd src dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPDATA/responses/*", "$RESOURCE/static/*"]
        }
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["yakumo"]
      }
    }
  },
  "bundle": {
    "icon": [
      "icons/release/32x32.png",
      "icons/release/128x128.png",
      "icons/release/128x128@2x.png",
      "icons/release/icon.icns",
      "icons/release/icon.ico"
    ],
    "resources": ["static"]
  }
}
