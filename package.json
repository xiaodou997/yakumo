{
  "name": "yakumo-app",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git"
  },
  "workspaces": [
    "packages/*",
    "src-tauri",
    "crates/*",
    "src"
  ],
  "scripts": {
    "init": "bun install && bun run bootstrap",
    "start": "bun run dev",
    "dev": "bun run app-dev",
    "app-build": "tauri build",
    "app-dev": "node scripts/run-dev.mjs",
    "migration": "node scripts/create-migration.cjs",
    "build": "bun run bootstrap:install-wasm-pack && bun run --workspaces --if-present --sequential build",
    "test": "bun run --workspaces --if-present test",
    "icons": "bun run icons:dev && bun run icons:release",
    "icons:dev": "tauri icon src-tauri/icons/icon-dev.png --output src-tauri/icons/dev",
    "icons:release": "tauri icon src-tauri/icons/icon.png --output src-tauri/icons/release",
    "bootstrap": "bun run bootstrap:install-wasm-pack && bun run bootstrap:build && bun run bootstrap:vendor",
    "bootstrap:install-wasm-pack": "node scripts/install-wasm-pack.cjs",
    "bootstrap:build": "bun run build",
    "bootstrap:vendor": "bun run vendor",
    "vendor": "bun run vendor:vendor-protoc",
    "vendor:vendor-protoc": "node scripts/vendor-protoc.cjs",
    "format": "biome format --write .",
    "lint": "biome lint . && bun run lint:workspaces",
    "lint:workspaces": "bun run --workspaces --if-present lint",
    "typecheck": "tsc --noEmit && bun run --workspaces --if-present typecheck",
    "replace-version": "node scripts/replace-version.cjs",
    "tauri": "tauri",
    "tauri-before-build": "bun run bootstrap",
    "tauri-before-dev": "node scripts/ensure-vendored.mjs && node scripts/run-workspaces-dev.mjs"
  },
  "dependencies": {
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/legacy-modes": "^6.5.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "dotenv-cli": "^11.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vite": "^8.0.10",
    "@biomejs/biome": "^2.3.8"
  },
  "overrides": {
    "js-yaml": "^4.1.1"
  },
  "packageManager": "bun@1.3.13"
}
