{
  "name": "yakumo-app",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git"
  },
  "workspaces": [
    "src-tauri",
    "crates/*",
    "src"
  ],
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "build": "node scripts/install-wasm-pack.cjs && bun run --cwd crates/yakumo-templates build && bun run --cwd src build",
    "typecheck": "tsc --noEmit && bun run --cwd src typecheck",
    "lint": "biome lint . && bun run --cwd src lint",
    "test": "bun test src",
    "format": "biome format --write .",
    "vendor:protoc": "node scripts/vendor-protoc.cjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/legacy-modes": "^6.5.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@tauri-apps/cli": "^2.10.1",
    "decompress": "^4.2.1",
    "dotenv-cli": "^11.0.0",
    "nodejs-file-downloader": "^4.13.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "js-yaml": "^4.1.1"
  },
  "packageManager": "bun@1.3.13"
}
