{
  "name": "yakumo-app",
  "version": "0.0.2",
  "private": true,
  "repository": {
    "type": "git"
  },
  "workspaces": [
    "src-tauri",
    "crates/*",
    "src"
  ],
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "build": "node scripts/install-wasm-pack.cjs && bun run --cwd crates/yakumo-templates build && bun run --cwd src build",
    "typecheck": "tsc --noEmit && bun run --cwd src typecheck",
    "lint": "biome lint . && bun run --cwd src lint",
    "test": "bun test src",
    "format": "biome format --write .",
    "tauri": "tauri"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@tauri-apps/cli": "^2.10.1",
    "decompress": "^4.2.1",
    "dotenv-cli": "^11.0.0",
    "nodejs-file-downloader": "^4.13.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@types/node": "^22.12.0",
    "js-yaml": "^4.1.1"
  },
  "packageManager": "bun@1.3.13"
}
